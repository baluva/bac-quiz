# Copie ce fichier en .env et remplis tes valeurs Supabase
# (Dashboard Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# URL publique définitive du site, sans / final (SEO : canonical, OG, sitemap).
# À définir aussi dans les variables d'env Netlify.
VITE_SITE_URL=https://bac-quiz.netlify.app

# Token Cloudflare Web Analytics (vide = beacon non injecté).
# Cloudflare → Web Analytics → Add a site → copie le token.
VITE_CF_BEACON_TOKEN=

# Base où sont servis les PDF en production (laisse vide en dev → middleware Vite).
# En prod = URL publique du bucket Cloudflare R2, ex :
# VITE_EPREUVES_BASE=https://pub-xxxxxxxx.r2.dev

# --- Cloudflare R2 (uniquement pour le script d'upload des PDF, pas l'app) ---
# Cloudflare → R2. Crée un bucket + un token API "Object Read & Write".
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxx
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
# R2_BUCKET=bac-quiz-epreuves
